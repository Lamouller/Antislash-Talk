# 🎙️ Antislash Talk - Environment Configuration Example
# Copy this file to .env.monorepo and fill in your values

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=postgres
POSTGRES_PORT=5432
# Use a strong password (at least 32 characters recommended)
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# ============================================
# JWT Configuration
# ============================================
# Generate a secure JWT secret (at least 32 characters)
# You can generate one with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# JWT Keys for Supabase authentication
# Generate with: npm run generate-jwt-keys
# Or manually with the JWT secret above
ANON_KEY=your-anon-jwt-key-here
SERVICE_ROLE_KEY=your-service-role-jwt-key-here

# ============================================
# Application URLs
# ============================================
# Main site URL (where the web app is accessible)
SITE_URL=http://localhost:3000

# Supabase API URL (Kong gateway)
API_EXTERNAL_URL=http://localhost:54321
SUPABASE_PUBLIC_URL=http://localhost:54321

# ============================================
# Service Ports
# ============================================
# Kong gateway (Supabase API)
KONG_HTTP_PORT=54321
KONG_HTTPS_PORT=54320

# Supabase Studio admin interface
STUDIO_PORT=54323
STUDIO_PROXY_PORT=54327

# Web application
WEB_PORT=3000

# Database direct access (for debugging)
# Default: 54322 (mapped to container's 5432)
# POSTGRES_PORT=54322

# Email testing (Inbucket)
INBUCKET_PORT=54324
INBUCKET_SMTP_PORT=54325
INBUCKET_POP3_PORT=54326

# ============================================
# Email Configuration
# ============================================
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# For development, uses Inbucket (local email testing)
SMTP_ADMIN_EMAIL=admin@antislash-talk.local
SMTP_HOST=inbucket
SMTP_PORT=2500
SMTP_SENDER_NAME=Antislash Talk

# For production, configure real SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ============================================
# Supabase Studio Configuration
# ============================================
STUDIO_DEFAULT_ORGANIZATION=Antislash Talk
STUDIO_DEFAULT_PROJECT=Antislash Talk Project
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=password

# ============================================
# Frontend Build Configuration (Vite)
# ============================================
# These are injected at build time for the web app
VITE_SUPABASE_URL=${API_EXTERNAL_URL}
VITE_SUPABASE_ANON_KEY=${ANON_KEY}
VITE_HIDE_MARKETING_PAGES=false

# Optional: AI/ML Services URLs
# VITE_OLLAMA_URL=http://localhost:11434
# VITE_WHISPERX_URL=http://localhost:8082
# VITE_PYTORCH_SERVICE_URL=http://localhost:8000

# --------------------------------------------
# Feature flags - transcription refactor (phase 0+)
# Master kill-switch: setting to false forces ALL sub-flags to false
VITE_FLAG_NEW_TRANSCRIPTION_FLOW=false

# Sub-flags (activated progressively per phase)
VITE_FLAG_NORMALIZED_TIMESTAMPS=false
VITE_FLAG_SPEAKER_LOCK_DEDUP=false
VITE_FLAG_WS_RECONNECT=false
VITE_FLAG_CLIENT_VAD=false
VITE_FLAG_UNIFIED_MIC_STREAM=false
VITE_FLAG_PROVIDER_MUTEX=false
VITE_FLAG_MIC_ROUTE_HANDLING=false

# VAD tuning (used when CLIENT_VAD is on)
VITE_VAD_THRESHOLD_DB=-40
VITE_VAD_SILENCE_MS=400

# ============================================
# AI/ML Services (Optional)
# ============================================
# HuggingFace token for pyannote (speaker diarization)
# Get one at: https://huggingface.co/settings/tokens
# HUGGINGFACE_TOKEN=your-huggingface-token-here

# Ollama configuration
# OLLAMA_ORIGINS=http://localhost,https://localhost

# Logging level for transcription service
# LOG_LEVEL=INFO

# ============================================
# Edge Functions Configuration
# ============================================
# Optional: Netlify webhook URL for production async transcription
# If not set, transcriptions run directly in local mode
# NETLIFY_WEBHOOK_URL=https://your-netlify-function-url.netlify.app/.netlify/functions/transcribe

# Optional: PyTorch transcription service URL
# Only needed if using local PyTorch transcription (requires --profile pytorch)
# PYTORCH_SERVICE_URL=http://transcription-pytorch:8000

# ============================================
# Advanced Configuration
# ============================================
# PostgREST schemas to expose
PGRST_DB_SCHEMAS=public,storage,graphql_public

# Image proxy settings
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Additional redirect URLs for OAuth (comma-separated)
# ADDITIONAL_REDIRECT_URLS=http://localhost:3000,http://localhost:5173

# Disable user signups (for production)
# DISABLE_SIGNUP=false
